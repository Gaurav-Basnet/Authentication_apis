<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      font-family: Arial;
      background: #f4f4f4;
      padding: 20px;
    }
    .box {
      background: white;
      padding: 20px;
      border-radius: 10px;
      text-align: center;
    }
    .otp {
      font-size: 30px;
      letter-spacing: 5px;
      color: #2d6cdf;
      font-weight: bold;
    }
  </style>
</head>

<body>
  <div class="box">
    <h2>Verify Your Email</h2>
    <p>Your OTP code is:</p>
    <div class="otp"><%= otp %></div>
    <p>This OTP will expire in 10 minutes.</p>
  </div>
</body>
</html>